{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c \"python tools\\hooks\\shadow_sync.py\"",
            "timeout": 30,
            "statusMessage": "Shadow auto-sync: casa espelho publicado com origin (ADR-070; no-op em master)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c \"python tools\\repo_mode.py\"",
            "timeout": 10,
            "statusMessage": "Modo por identidade: shadow=USER (aplica a dominio), master=DEV (ADR-070/072)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \".claude\\hooks\\sync-global.ps1\"",
            "timeout": 30,
            "statusMessage": "Sincronizando framework para ~/.claude/"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \".claude\\hooks\\check-execution-mode.ps1\"",
            "timeout": 10,
            "statusMessage": "Verificando modo de execucao do framework"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c \"python tools\\hooks\\check_repo_sync.py || powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude\\hooks\\check-repo-sync.ps1\"",
            "timeout": 30,
            "statusMessage": "Verificando sincronizacao do repo com origin (ADR-019/060: python->powershell)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c \"python tools\\hooks\\check_core_agnostic_hook.py || powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude\\hooks\\check-core-agnostic.ps1\"",
            "timeout": 20,
            "statusMessage": "Verificando agnosticismo do nucleo (ADR-020/061: python->powershell)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \".claude\\hooks\\inject-start-session.ps1\"",
            "timeout": 10,
            "statusMessage": "Ativando auto-boot do squad (delete .claude/session.lock se nao quiser)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"tools\\hooks\\mission-gate.ps1\"",
            "timeout": 10,
            "statusMessage": "Verificando product_type/escopo (mission-gate ADR-022)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"tools\\hooks\\route-gate.ps1\"",
            "timeout": 10,
            "statusMessage": "Roteamento determinístico (route-gate ADR-027)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"tools\\hooks\\effect-gate.ps1\"",
            "timeout": 10,
            "statusMessage": "Gate de acoes destrutivas por efeito (effect-gate ADR-015)"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c \"python tools\\hooks\\prepush_sync_guard.py || exit /b 0\"",
            "timeout": 20,
            "statusMessage": "Guard de pre-push: barra push sobre base atrasada (ADR-060)"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c \"python tools\\hooks\\shadow_write_guard.py || exit /b 0\"",
            "timeout": 20,
            "statusMessage": "Shadow-write-guard: NEGA push de espelho publicado (ADR-070; no-op em master)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"tools\\hooks\\overwrite-guard.ps1\"",
            "timeout": 10,
            "statusMessage": "Anti-overwrite cego de artefato (overwrite-guard ADR-037)"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c \"python tools\\hooks\\context_budget_gate.py || exit /b 0\"",
            "timeout": 10,
            "statusMessage": "Context-budget: anuncia fracionar (doc-intake) em leitura de fonte grande (ADR-029)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"tools\\hooks\\overwrite-guard.ps1\"",
            "timeout": 10,
            "statusMessage": "Registro de arquivos lidos/criados na sessao (overwrite-guard ADR-037)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"tools\\hooks\\compaction-gate.ps1\"",
            "timeout": 10,
            "statusMessage": "Verificando digest antes de compactar (ADR-021)"
          }
        ]
      }
    ]
  }
}
